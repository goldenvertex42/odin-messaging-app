// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProfileTheme {
  SLATE
  EMERALD
  OCEAN
  AMETHYST
  ROSE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String?        // Nullable to allow for future 3rd-party OAuth
  username        String         @unique
  displayName     String?
  avatarUrl       String?
  bio             String?
  
  themePreference ProfileTheme   @default(SLATE)
  
  isOnline        Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  sentMessages    Message[]
  participants    Participant[]

  // Self-referencing relations for the Friends List
  friendsAdded    Friendship[]   @relation("UserSender")
  friendsOf       Friendship[]   @relation("UserReceiver")

  @@map("user")
}

model Conversation {
  id           String        @id @default(uuid())
  name         String?       // Nullable for 1-on-1 chats; populated for Group Chats
  isGroup      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  participants Participant[]
  messages     Message[]

  @@map("conversation")
}

model Participant {
  id             String       @id @default(uuid())
  userId         String
  conversationId String
  isAdmin        Boolean      @default(false) // Useful for group chat moderation
  joinedAt       DateTime     @default(now())

  // Relations
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId]) // Prevents adding a user twice to the same chat
  @@map("participant")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String?      // Nullable to allow sending an image only
  fileUrl        String?      // Stores the URL for image uploads
  createdAt      DateTime     @default(now())

  // Relations
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("message")
}

model Friendship {
  id         String           @id @default(uuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  // Relations
  sender     User             @relation("UserSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User             @relation("UserReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId]) // Prevents duplicate request entries
  @@map("friendship")
}
